{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist/lib",
    "rootDir": "src",
    "noEmit": false,
    "composite": true,
    "tsBuildInfoFile": "dist/.tsbuildinfo",
    "jsx": "react-jsx",
    "allowJs": false,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "types": ["node", "vite/client"]
  },
  "include": ["src/**/*", "src/**/*.json"],
  "exclude": ["dist", "node_modules"],
  "references": [{ "path": "../types" }]
}
