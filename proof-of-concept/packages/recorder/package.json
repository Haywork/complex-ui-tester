{
  "name": "@haywork/cuit-recorder",
  "version": "0.2.0",
  "description": "CUIT session recorder core",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./translate-ui-react-bridge": {
      "types": "./dist/translate-ui-react-bridge.d.ts",
      "import": "./dist/translate-ui-react-bridge.js",
      "default": "./dist/translate-ui-react-bridge.js"
    }
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Haywork/complex-ui-tester.git",
    "directory": "proof-of-concept/packages/recorder"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepublishOnly": "pnpm run build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@haywork/cuit-types": "workspace:*"
  },
  "devDependencies": {
    "@types/jsdom": "^21.1.7",
    "jsdom": "^25.0.0",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5"
  }
}
