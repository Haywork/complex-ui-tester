{
  "name": "@haywork/recorder-extension",
  "version": "0.2.0",
  "private": true,
  "description": "Chrome MV3 extension wrapper around @haywork/cuit-recorder.",
  "type": "module",
  "scripts": {
    "validate": "node scripts/validate.mjs",
    "test": "vitest run",
    "build": "node build.mjs && node scripts/validate.mjs",
    "lint": "echo 'no lint step' && exit 0",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "files": [
    "manifest.json",
    "background.js",
    "content.js",
    "popup.html",
    "popup.js",
    "icons/"
  ],
  "devDependencies": {
    "@haywork/cuit-recorder": "workspace:*",
    "@haywork/cuit-types": "workspace:*",
    "@types/node": "^20.14.0",
    "esbuild": "^0.21.5",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5"
  }
}
