{
  "name": "@haywork/cuit-mcp-local",
  "version": "0.2.0",
  "description": "Local MCP tool descriptors for CUIT proof-of-concept",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Haywork/complex-ui-tester.git",
    "directory": "proof-of-concept/packages/mcp-local"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepublishOnly": "pnpm run build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@haywork/cuit-harness": "workspace:*",
    "@haywork/cuit-spec-gen": "workspace:*",
    "@haywork/cuit-types": "workspace:*"
  },
  "devDependencies": {
    "@haywork/adapter-cuit": "workspace:*",
    "@haywork/adapter-jam": "workspace:*",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5"
  },
  "peerDependencies": {
    "@haywork/adapter-cuit": "*",
    "@haywork/adapter-jam": "*"
  },
  "peerDependenciesMeta": {
    "@haywork/adapter-cuit": {
      "optional": true
    },
    "@haywork/adapter-jam": {
      "optional": true
    }
  }
}
